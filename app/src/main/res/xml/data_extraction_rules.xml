<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules. Matches backup_rules.xml in intent:
     never carry the location cache between devices. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="sky_widget_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="sky_widget_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
