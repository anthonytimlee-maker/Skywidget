<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget provider metadata.

  - minWidth/minHeight: 4x1 cell footprint. Android's cell-counting formula
    ((dp + 30) / 70, round up) gives 4 cells wide at 250dp, 1 cell tall at 40dp.
  - targetCellWidth/Height: exact 4x1 for API 31+ launchers that honor it.
  - minResize*: lowered so users can shrink the widget to 3x1 via long-press drag.
  - resizeMode: both axes allowed.
  - updatePeriodMillis=0 because WorkManager drives our 15-min refresh.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="40dp"
    android:minResizeWidth="180dp"
    android:minResizeHeight="40dp"
    android:targetCellWidth="4"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:previewLayout="@layout/sky_widget"
    android:initialLayout="@layout/sky_widget"
    android:configure="com.anthony.skywidget.config.ConfigActivity"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_description" />
