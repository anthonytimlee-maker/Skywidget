<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme — DayNight follows the device's light/dark mode
         setting. The widget itself doesn't use this theme (its background is
         always the dynamic sky gradient), but the config activity does. -->
    <style name="Theme.SkyWidget" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:attr/colorBackground</item>
    </style>

    <!-- Config activity uses the same theme; override here if you want the
         setup screen to look different from a hypothetical future main activity. -->
    <style name="Theme.SkyWidget.Config" parent="Theme.SkyWidget" />
</resources>
