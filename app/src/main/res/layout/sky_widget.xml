<?xml version="1.0" encoding="utf-8"?>
<!--
  DIAGNOSTIC LAYOUT — STEP 4
  Added: weather icon as an ImageView in column 2, using a vector drawable.
  Still no small icons for the stats, no gradient.

  Purpose: verify that vector drawables inflate in RemoteViews ImageViews.
  If this breaks, we know it's a vector-drawable issue specifically.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#4A9BCF"
    android:padding="8dp"
    android:baselineAligned="false">

    <!-- Column 1: temp + H/L stacked -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/temp_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:text="18°" />

        <TextView
            android:id="@+id/temp_hl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:text="21° / 9°" />
    </LinearLayout>

    <!-- Column 2: weather icon (+ chips placeholder below for now) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginStart="14dp">

        <ImageView
            android:id="@+id/ico_weather"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_partly_cloudy_day"
            android:contentDescription="@string/cd_weather_icon" />

        <TextView
            android:id="@+id/chips_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:text="chips" />
    </LinearLayout>

    <!-- Column 3: sun stats, weight=1 to claim remaining width, left-aligned -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="start|center_vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/sunrise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:text="—" />

        <TextView
            android:id="@+id/sunset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:text="—" />

        <TextView
            android:id="@+id/daylight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:text="—" />
    </LinearLayout>

</LinearLayout>
