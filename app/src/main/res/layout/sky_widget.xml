<?xml version="1.0" encoding="utf-8"?>
<!--
  DIAGNOSTIC LAYOUT — STEP 6
  Added: FrameLayout root wrapping a background ImageView (painted by the
  renderer as a runtime-generated bitmap gradient) and the content row
  above it.

  Purpose: verify that setImageViewBitmap works on a full-bleed ImageView
  in RemoteViews, and that FrameLayout with two children (image + linear
  layout) renders correctly.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background: dynamically-painted gradient bitmap. -->
    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />

    <!-- Content row, same as Step 5 but with the solid-color background removed
         (the gradient image below provides the color now). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:baselineAligned="false">

        <!-- Column 1: temp + H/L stacked -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/temp_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="36sp"
                android:textColor="#FFFFFF"
                android:text="18°" />

            <TextView
                android:id="@+id/temp_hl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:text="21° / 9°" />
        </LinearLayout>

        <!-- Column 2: weather icon + chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="14dp">

            <ImageView
                android:id="@+id/ico_weather"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_partly_cloudy_day"
                android:contentDescription="@string/cd_weather_icon" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_precip"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/precip_pct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="3dp"
                    android:text="20%" />

                <ImageView
                    android:id="@+id/ico_baro"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_baro_flat"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/cd_baro_trend" />
            </LinearLayout>
        </LinearLayout>

        <!-- Column 3: sun stats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="start|center_vertical"
            android:layout_marginStart="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_sunrise"
                    android:contentDescription="@null" />
                <TextView
                    android:id="@+id/sunrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="5dp"
                    android:text="—" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">
                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_sunset"
                    android:contentDescription="@null" />
                <TextView
                    android:id="@+id/sunset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="5dp"
                    android:text="—" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">
                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_daylight"
                    android:contentDescription="@null" />
                <TextView
                    android:id="@+id/daylight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="5dp"
                    android:text="—" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
