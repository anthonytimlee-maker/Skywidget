<?xml version="1.0" encoding="utf-8"?>
<!--
  Test 7.3 — includeFontPadding and lineSpacingMultiplier removed.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:baselineAligned="false">

        <!-- Column 1: temp + H/L stacked -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/temp_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="54sp"
                android:fontFamily="sans-serif-medium"
                android:text="18°" />

            <TextView
                android:id="@+id/temp_hl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="1dp"
                android:text="21° / 9°" />
        </LinearLayout>

        <!-- Column 2: weather icon + chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="14dp">

            <ImageView
                android:id="@+id/ico_weather"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:src="@drawable/ic_partly_cloudy_day"
                android:contentDescription="@string/cd_weather_icon" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/ico_precip"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_precip"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/precip_pct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="3dp"
                    android:text="20%" />

                <ImageView
                    android:id="@+id/ico_baro"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_baro_flat"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/cd_baro_trend" />
            </LinearLayout>
        </LinearLayout>

        <!-- Column 3: sun stats, weight=1, left-aligned -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="start|center_vertical"
            android:layout_marginStart="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ico_sunrise"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_sunrise"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/sunrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="6dp"
                    android:text="6:12 AM" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="5dp">

                <ImageView
                    android:id="@+id/ico_sunset"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_sunset"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/sunset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="6dp"
                    android:text="7:48 PM" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="5dp">

                <ImageView
                    android:id="@+id/ico_daylight"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_daylight"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/daylight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="6dp"
                    android:text="13h 36m" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
