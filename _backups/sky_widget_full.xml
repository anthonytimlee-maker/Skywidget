<?xml version="1.0" encoding="utf-8"?>
<!--
  Sky widget layout — 3x1 Android home-screen widget.

  Maps directly to Stage 4b's flexbox layout:
    col-temp  (wrap_content)      — current temp stacked over "21° / 9°"
    col-cond  (wrap_content)      — weather icon over precip+baro chip row
    col-sun   (weight=1)          — sunrise/sunset/daylight, left-aligned

  The FrameLayout root lets us layer the gradient bitmap underneath the
  content LinearLayout. RemoteViews has very limited view support, so we
  stick to FrameLayout, LinearLayout, TextView, and ImageView.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToOutline="true">

    <!-- Background gradient. The worker paints a bitmap here every refresh.
         scaleType=fitXY stretches the tiny source bitmap to fill the widget. -->
    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />

    <!-- Content row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:baselineAligned="false">

        <!-- Column 1: current temp over H/L -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/temp_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="54sp"
                android:textStyle="normal"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:lineSpacingMultiplier="0.95"
                android:text="18°"
                android:contentDescription="@string/cd_current_temp" />

            <TextView
                android:id="@+id/temp_hl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.85"
                android:layout_marginTop="1dp"
                android:includeFontPadding="false"
                android:text="21° / 9°"
                android:contentDescription="@string/cd_high_low" />
        </LinearLayout>

        <!-- Column gap -->
        <Space
            android:layout_width="14dp"
            android:layout_height="0dp" />

        <!-- Column 2: weather icon + precip/baro chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/ico_weather"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:contentDescription="@string/cd_weather_icon" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/ico_precip"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_precip"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/precip_pct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:layout_marginStart="3dp"
                    android:text="20%" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <ImageView
                    android:id="@+id/ico_baro"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:contentDescription="@string/cd_baro_trend" />
            </LinearLayout>
        </LinearLayout>

        <!-- Column gap -->
        <Space
            android:layout_width="14dp"
            android:layout_height="0dp" />

        <!-- Column 3: sunrise / sunset / daylight, left-aligned, weight=1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="start|center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ico_sunrise"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_sunrise"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/sunrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"
                    android:text="6:12 AM" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="5dp">

                <ImageView
                    android:id="@+id/ico_sunset"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_sunset"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/sunset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"
                    android:text="7:48 PM" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="5dp">

                <ImageView
                    android:id="@+id/ico_daylight"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_daylight"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/daylight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:layout_marginStart="6dp"
                    android:text="13h 36m" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
